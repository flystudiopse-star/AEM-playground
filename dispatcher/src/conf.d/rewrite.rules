# Dispatcher configuration for AEM

# Load mod_rewrite
LoadModule rewrite_module modules/mod_rewrite.so

# Enable rewrite engine
RewriteEngine On

# Rewrite rules for AEM
RewriteCond %{REQUEST_URI} ^/content/dam/.*$
RewriteRule ^/(.*)$ /dispatcher/$1 [L]

# Block access to JCR metadata
RewriteRule ^/\.git/.*$ - [F,L]
RewriteRule ^/\.svn/.*$ - [F,L]

# Allow static resources
RewriteCond %{REQUEST_URI} !^/content$
RewriteCond %{REQUEST_URI} !^/etc$
RewriteCond %{REQUEST_URI} !^/apps
RewriteRule ^/(.*)$ - [L]

# Block access to sensitive paths
<LocationMatch "^/apps/(.*)/config(.*)?$">
    Order deny,allow
    Deny from all
</LocationMatch>

<LocationMatch "^/libs/(.*)/config(.*)?$">
    Order deny,allow
    Deny from all
</LocationMatch>

# Caching headers
<IfModule mod_headers.c>
    # Cache static content for 1 year
    <LocationMatch "\.(css|js|jpg|jpeg|png|gif|ico|svg|woff|woff2|ttf|eot)$">
        Header set Cache-Control "max-age=31536000, public"
    </LocationMatch>
    
    # No cache for HTML
    <LocationMatch "\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </LocationMatch>
</IfModule>